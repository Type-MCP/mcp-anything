        self.timeout = float(os.environ.get(
            f"{_ENV_PREFIX}_TIMEOUT", str(_DEFAULT_TIMEOUT),
        ))

    async def execute(self, method: str, **kwargs: Any) -> str:
        """Send a command via the {{ protocol }} protocol.

        Override this method to implement {{ protocol }}-specific communication.
        """
        raise NotImplementedError(
            f"{{ protocol }} backend for '{method}' requires manual wiring. "
            f"Override Backend.execute() with your {{ protocol }} client logic."
        )

    async def query(self, uri: str) -> str:
        """Query a resource via {{ protocol }}."""
        return await self.execute("query", uri=uri)
