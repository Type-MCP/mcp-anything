"""Unit tests for the generated {{ design.server_name }} backend."""

import asyncio
import json
import types
from unittest.mock import AsyncMock

import pytest

from {{ package_name }}.backend import Backend


def _run(awaitable):
    """Run async backend helpers in synchronous pytest tests."""
    return asyncio.run(awaitable)


{% set has_http_tools = design.tools | selectattr('impl.strategy', 'equalto', 'http_call') | list | length > 0 %}
{% if has_http_tools %}
class TestHttpBackend:
    """Verify HTTP backend response formatting."""

    def test_request_pretty_prints_json_response(self, monkeypatch):
        backend = Backend()

        class FakeResponse:
            status_code = 200
            text = '{"ok": true}'

            def json(self):
                return {"ok": True}

        fake_client = types.SimpleNamespace(request=AsyncMock(return_value=FakeResponse()))
        monkeypatch.setattr(backend, "_get_client", AsyncMock(return_value=fake_client))

        result = _run(backend.request("GET", "/items"))

        assert json.loads(result) == {"ok": True}
        fake_client.request.assert_awaited_once()

    def test_request_returns_raw_text_when_json_parsing_fails(self, monkeypatch):
        backend = Backend()

        class FakeResponse:
            status_code = 200
            text = "plain-text-response"

            def json(self):
                raise ValueError("not json")

        fake_client = types.SimpleNamespace(request=AsyncMock(return_value=FakeResponse()))
        monkeypatch.setattr(backend, "_get_client", AsyncMock(return_value=fake_client))

        result = _run(backend.request("GET", "/items"))

        assert result == "plain-text-response"
{% elif design.backend.backend_type.value == "protocol" and (design.backend.env_vars.get("PROTOCOL") == "websocket" or not design.backend.env_vars.get("PROTOCOL")) %}
class TestWebSocketBackend:
    """Verify WebSocket protocol response handling."""

    def test_execute_formats_jsonrpc_object_result(self, monkeypatch):
        backend = Backend()

        class FakeConnection:
            def __init__(self):
                self.send = AsyncMock()
                self.recv = AsyncMock(return_value=json.dumps({
                    "jsonrpc": "2.0",
                    "id": 1,
                    "result": {"ok": True},
                }))

        fake_connection = FakeConnection()
        monkeypatch.setattr(backend, "_get_connection", AsyncMock(return_value=fake_connection))

        result = _run(backend.execute("demo_method", item_id=7))

        assert json.loads(result) == {"ok": True}
        fake_connection.send.assert_awaited_once()
        request = json.loads(fake_connection.send.await_args.args[0])
        assert request["method"] == "demo_method"
        assert request["params"] == {"item_id": 7}

    def test_execute_returns_raw_text_when_response_is_not_jsonrpc(self, monkeypatch):
        backend = Backend()

        class FakeConnection:
            def __init__(self):
                self.send = AsyncMock()
                self.recv = AsyncMock(return_value="plain-text-response")

        fake_connection = FakeConnection()
        monkeypatch.setattr(backend, "_get_connection", AsyncMock(return_value=fake_connection))

        result = _run(backend.execute("demo_method"))

        assert result == "plain-text-response"
{% elif design.backend.backend_type.value == "protocol" %}
class TestProtocolBackend:
    """Verify scaffolding protocol backend behavior."""

    def test_query_delegates_to_execute(self, monkeypatch):
        backend = Backend()
        mock_execute = AsyncMock(return_value="protocol-ok")
        monkeypatch.setattr(backend, "execute", mock_execute)

        result = _run(backend.query("app://{{ design.server_name }}/status"))

        assert result == "protocol-ok"
        mock_execute.assert_awaited_once_with("query", uri="app://{{ design.server_name }}/status")
{% elif design.backend.backend_type.value == "cli" %}
class TestCliBackend:
    """Verify CLI backend output handling."""

    def test_run_cli_returns_stdout(self, monkeypatch):
        backend = Backend()

        class FakeProcess:
            returncode = 0

            async def communicate(self):
                return (b"stdout-value\n", b"stderr-value\n")

        monkeypatch.setattr(
            asyncio,
            "create_subprocess_exec",
            AsyncMock(return_value=FakeProcess()),
        )

        result = _run(backend.run_cli(["status"]))

        assert result == "stdout-value"

    def test_run_cli_falls_back_to_stderr(self, monkeypatch):
        backend = Backend()

        class FakeProcess:
            returncode = 0

            async def communicate(self):
                return (b"", b"stderr-only\n")

        monkeypatch.setattr(
            asyncio,
            "create_subprocess_exec",
            AsyncMock(return_value=FakeProcess()),
        )

        result = _run(backend.run_cli(["status"]))

        assert result == "stderr-only"
{% elif design.backend.backend_type.value == "python-api" %}
class TestPythonApiBackend:
    """Verify Python API backend result normalization."""

    def test_call_function_stringifies_result(self, monkeypatch):
        backend = Backend()
        fake_module = types.SimpleNamespace(example=lambda **_kwargs: {"ok": True})

        monkeypatch.setattr(
            __import__("importlib"),
            "import_module",
            lambda _module_name: fake_module,
        )

        result = _run(backend.call_function("fake.module", "example"))

        assert result == "{'ok': True}"
