FROM python:3.12-slim

WORKDIR /app

COPY pyproject.toml .
COPY src/ src/

RUN pip install --no-cache-dir -e .
{% if design.target_install_hint %}

# Install target application dependencies
RUN {{ design.target_install_hint }}
{% endif %}

ENV MCP_TRANSPORT=http
ENV MCP_HOST=0.0.0.0
ENV MCP_PORT={{ design.http_port }}

EXPOSE {{ design.http_port }}

CMD ["mcp-{{ design.server_name | kebab_case }}"]
