"""Resources for {{ design.server_name }}."""

import json

from mcp.server.fastmcp import FastMCP


def register_resources(server: FastMCP{% if design.backend %}, backend{% endif %}) -> None:
    """Register resources with the server."""

{% for resource in design.resources %}
    @server.resource("{{ resource.uri }}")
    async def {{ resource.name | snake_case }}() -> str:
        """{{ resource.description | safe_docstring }}"""
    {% if resource.resource_type == "status" %}
        {% if design.backend and design.backend.backend_type.value == "cli" %}
        try:
            version = await backend.run_cli(["--version"])
        except Exception:
            version = "unknown"
        return json.dumps({
            "name": "{{ design.server_name }}",
            "version": version.strip(),
            "status": "running",
        }, indent=2)
        {% elif design.backend and design.backend.backend_type.value == "python-api" %}
        return json.dumps({
            "name": "{{ design.server_name }}",
            "status": "running",
        }, indent=2)
        {% else %}
        return json.dumps({
            "name": "{{ design.server_name }}",
            "status": "running",
        }, indent=2)
        {% endif %}
    {% elif resource.resource_type == "commands" %}
        tools = server.list_tools()
        commands = []
        for tool in tools:
            commands.append({
                "name": tool.name,
                "description": tool.description or "",
            })
        return json.dumps({"commands": commands}, indent=2)
    {% elif resource.resource_type == "config" %}
        {% if design.backend and design.backend.backend_type.value == "cli" %}
        try:
            config_output = await backend.run_cli(["--help"])
        except Exception:
            config_output = "Could not retrieve configuration"
        return json.dumps({
            "help": config_output,
            "codebase_path": str(backend.codebase_path),
        }, indent=2)
        {% else %}
        return json.dumps({
            "note": "Configuration resource for {{ design.server_name }}",
        }, indent=2)
        {% endif %}
    {% elif resource.resource_type == "docs" %}
        # Dynamic documentation resource
        tools = server.list_tools()
        doc_entries = []
        for tool in tools:
            entry = {"name": tool.name, "description": tool.description or ""}
            if hasattr(tool, "inputSchema") and tool.inputSchema:
                entry["parameters"] = tool.inputSchema.get("properties", {})
                entry["required"] = tool.inputSchema.get("required", [])
            doc_entries.append(entry)
        return json.dumps({
            "server": "{{ design.server_name }}",
            "resource": "{{ resource.uri }}",
            "tools": doc_entries,
        }, indent=2)
    {% else %}
        {% if design.backend %}
        return await backend.query("{{ resource.uri }}")
        {% else %}
        return json.dumps({"resource": "{{ resource.uri }}"})
        {% endif %}
    {% endif %}

{% endfor %}
