{% for prompt in design.prompts %}
    def test_get_prompt_{{ prompt.name }}(self, server):
        prompt_result = _run(server.get_prompt("{{ prompt.name }}", {
{% for arg in prompt.arguments %}
            "{{ arg.name }}": {{ sample_value(arg.type, arg.name) }},
{% endfor %}
        }))
        assert prompt_result.messages
        message = prompt_result.messages[0]
        assert getattr(message.content, "text", "")

